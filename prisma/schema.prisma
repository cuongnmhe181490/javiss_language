generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  pending
  approved
  verification_sent
  active
  rejected
  blocked
}

enum RegistrationStatus {
  pending
  approved
  rejected
}

enum NotificationStatus {
  unread
  read
  archived
}

enum AuditAction {
  registration_created
  registration_approved
  registration_rejected
  verification_code_sent
  verification_succeeded
  verification_failed
  verification_resent
  user_blocked
  user_unblocked
  login_succeeded
  login_failed
  password_reset_requested
  password_reset_completed
  lesson_created
  exercise_created
  settings_updated
  admin_created
  profile_updated
}

enum LicenseStatus {
  draft
  active
  expired
  revoked
}

enum EntitlementStatus {
  active
  inactive
  expired
}

enum FeatureFlagType {
  boolean
  percentage
  json
}

enum GoalStatus {
  draft
  active
  completed
  paused
}

enum PlanStatus {
  draft
  active
  completed
  archived
}

enum ExerciseType {
  practice
  mock_test
  assessment
}

enum QuestionType {
  multiple_choice
  short_answer
  essay
  speaking
  listening
  reading
}

enum LessonStatus {
  draft
  published
  archived
}

enum PromptType {
  onboarding
  evaluation
  feedback
  study_plan
}

enum AttemptStatus {
  draft
  submitted
  reviewed
}

enum AiProvider {
  mock
  openai
  gemini
}

enum AiMessageRole {
  user
  assistant
}

enum AiConversationKind {
  coach
  speaking_mock
}

enum WritingTaskType {
  task1
  task2
}

enum AnalyticsEventType {
  writing_feedback_requested
  writing_feedback_completed
  writing_feedback_fallback_used
  public_chat_widget_opened
  public_chat_message_requested
  public_chat_message_completed
  public_chat_fallback_used
  public_chat_action_clicked
  landing_cta_clicked
  registration_submitted
  registration_approved
  registration_rejected
  account_activated
  learner_dashboard_first_visited
  lesson_catalog_first_opened
  speaking_mock_first_started
  writing_feedback_first_completed
}

model User {
  id                String                @id @default(cuid())
  tenantId          String?
  email             String                @unique
  passwordHash      String
  sessionVersion    Int                   @default(0)
  status            UserStatus            @default(pending)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  profile           UserProfile?
  roles             UserRole[]
  registrations     RegistrationRequest[]
  verificationCodes VerificationCode[]
  passwordResetTokens PasswordResetToken[]
  notifications     AdminNotification[]   @relation("NotificationRecipient")
  auditLogs         AuditLog[]            @relation("AuditActor")
  goals             Goal[]
  skillProfiles     SkillProfile[]
  studyPlans        StudyPlan[]
  snapshots         ProgressSnapshot[]
  entitlements      UserEntitlement[]
  licenses          License[]
  attempts          ExerciseAttempt[]
  aiConversations   AiConversation[]
  writingFeedbackSubmissions WritingFeedbackSubmission[]
  analyticsEvents   AnalyticsEvent[]

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

model UserProfile {
  id                   String    @id @default(cuid())
  tenantId             String?
  userId               String    @unique
  fullName             String
  preferredLocale      String    @default("vi")
  preferredLanguageId  String?
  currentLevel         String?
  strongestSkills      String[]
  weakestSkills        String[]
  preferredStudyWindow String?
  examDate             DateTime?
  onboardingNotes      String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredLanguage    Language? @relation(fields: [preferredLanguageId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

model Role {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       UserRole[]
}

model UserRole {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([tenantId])
}

model RegistrationRequest {
  id                  String             @id @default(cuid())
  tenantId            String?
  userId              String
  fullName            String
  email               String
  targetExamId        String?
  targetScore         String?
  preferredLanguageId String?
  notes               String?
  status              RegistrationStatus @default(pending)
  reviewedById        String?
  reviewedAt          DateTime?
  rejectionReason     String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetExam          Exam?              @relation(fields: [targetExamId], references: [id], onDelete: SetNull)
  preferredLanguage   Language?          @relation(fields: [preferredLanguageId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([email])
  @@index([status])
}

model VerificationCode {
  id           String   @id @default(cuid())
  tenantId     String?
  userId       String
  codeHash     String
  expiresAt    DateTime
  usedAt       DateTime?
  attemptCount Int      @default(0)
  sentToEmail  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model PasswordResetToken {
  id           String   @id @default(cuid())
  tenantId     String?
  userId       String
  tokenHash    String   @unique
  expiresAt    DateTime
  usedAt       DateTime?
  sentToEmail  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
}

model AdminNotification {
  id          String             @id @default(cuid())
  tenantId    String?
  recipientId String?
  title       String
  body        String
  entityType  String
  entityId    String
  status      NotificationStatus @default(unread)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  recipient   User?              @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([entityType, entityId])
}

model AuditLog {
  id          String      @id @default(cuid())
  tenantId    String?
  actorId     String?
  action      AuditAction
  targetType  String
  targetId    String
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime    @default(now())
  actor       User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  tenantId    String?
  code        String   @unique
  name        String
  description String?
  isDefault   Boolean  @default(false)
  priceCents  Int      @default(0)
  currency    String   @default("VND")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  licenses    License[]
  entitlements UserEntitlement[]
}

model License {
  id          String        @id @default(cuid())
  tenantId    String?
  userId      String
  planId      String
  status      LicenseStatus @default(active)
  startsAt    DateTime      @default(now())
  endsAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, status])
}

model UserEntitlement {
  id          String            @id @default(cuid())
  tenantId    String?
  userId      String
  planId      String?
  featureKey  String
  status      EntitlementStatus @default(active)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId, status])
  @@index([featureKey])
}

model FeatureFlag {
  id          String          @id @default(cuid())
  tenantId    String?
  key         String          @unique
  name        String
  description String?
  type        FeatureFlagType @default(boolean)
  value       Json
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Language {
  id          String        @id @default(cuid())
  tenantId    String?
  code        String        @unique
  name        String
  nativeName  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  exams       Exam[]
  packs       ExamPack[]
  users       UserProfile[]
  goals       Goal[]
  topics      Topic[]
  registrations RegistrationRequest[]
}

model Exam {
  id          String      @id @default(cuid())
  tenantId    String?
  languageId  String
  code        String      @unique
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  language    Language    @relation(fields: [languageId], references: [id], onDelete: Cascade)
  packs       ExamPack[]
  goals       Goal[]
  registrations RegistrationRequest[]
}

model ExamPack {
  id          String      @id @default(cuid())
  tenantId    String?
  languageId  String
  examId      String
  code        String      @unique
  name        String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  language    Language    @relation(fields: [languageId], references: [id], onDelete: Cascade)
  exam        Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  topics      Topic[]
  rubrics     Rubric[]
  prompts     PromptTemplate[]
}

model Goal {
  id                String     @id @default(cuid())
  tenantId          String?
  userId            String
  examId            String
  languageId        String
  targetScore       String?
  estimatedLevel    String?
  targetExamDate    DateTime?
  preferredSchedule String?
  status            GoalStatus @default(active)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam              Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  language          Language   @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, status])
}

model SkillProfile {
  id          String   @id @default(cuid())
  tenantId    String?
  userId      String
  skillKey    String
  strength    Int      @default(0)
  weakness    Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, skillKey])
}

model StudyPlan {
  id             String     @id @default(cuid())
  tenantId       String?
  userId         String
  title          String
  summary        String?
  nextAction     String?
  status         PlanStatus @default(active)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, status])
}

model ProgressSnapshot {
  id               String   @id @default(cuid())
  tenantId         String?
  userId           String
  overallProgress  Int      @default(0)
  readingProgress  Int      @default(0)
  listeningProgress Int     @default(0)
  speakingProgress Int      @default(0)
  writingProgress  Int      @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, createdAt(sort: Desc)])
}

model WritingFeedbackSubmission {
  id             String          @id @default(cuid())
  tenantId       String?
  userId         String
  taskType       WritingTaskType
  prompt         String
  essay          String
  wordCount      Int
  overallBand    Float
  taskBand       Float
  coherenceBand  Float
  lexicalBand    Float
  grammarBand    Float
  summary        String
  strengths      String[]        @default([])
  improvements   String[]        @default([])
  sampleRewrite  String
  provider       AiProvider
  modelName      String
  fallbackReason String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([taskType, createdAt(sort: Desc)])
}

model AnalyticsEvent {
  id         String             @id @default(cuid())
  tenantId   String?
  userId     String?
  eventType  AnalyticsEventType
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  user       User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@index([entityType, entityId])
}

model Topic {
  id          String   @id @default(cuid())
  tenantId    String?
  examPackId  String
  languageId  String
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  examPack    ExamPack @relation(fields: [examPackId], references: [id], onDelete: Cascade)
  language    Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
}

model Lesson {
  id          String       @id @default(cuid())
  tenantId    String?
  topicId     String
  slug        String       @unique
  title       String
  summary     String?
  status      LessonStatus @default(draft)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  topic       Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  exercises   Exercise[]
}

model Exercise {
  id          String       @id @default(cuid())
  tenantId    String?
  lessonId    String
  slug        String       @unique
  title       String
  type        ExerciseType @default(practice)
  instructions String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions   Question[]
  attempts    ExerciseAttempt[]
}

model Question {
  id          String       @id @default(cuid())
  tenantId    String?
  exerciseId  String
  prompt      String
  type        QuestionType
  answerKey   Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  exercise    Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  attemptAnswers AttemptAnswer[]
}

model ExerciseAttempt {
  id          String        @id @default(cuid())
  tenantId    String?
  userId      String
  exerciseId  String
  status      AttemptStatus @default(draft)
  score       Int?
  feedback    String?
  startedAt   DateTime      @default(now())
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise      @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  answers     AttemptAnswer[]

  @@index([tenantId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([exerciseId, status])
}

model AttemptAnswer {
  id         String          @id @default(cuid())
  tenantId   String?
  attemptId  String
  questionId String
  answerText String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  attempt    ExerciseAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([tenantId])
}

model Rubric {
  id          String    @id @default(cuid())
  tenantId    String?
  examPackId  String
  skillKey    String
  title       String
  content     Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  examPack    ExamPack  @relation(fields: [examPackId], references: [id], onDelete: Cascade)

  @@index([examPackId, skillKey])
}

model PromptTemplate {
  id          String     @id @default(cuid())
  tenantId    String?
  examPackId  String
  type        PromptType
  key         String     @unique
  title       String
  content     String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  examPack    ExamPack   @relation(fields: [examPackId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AiConversation {
  id                    String      @id @default(cuid())
  tenantId              String?
  userId                String
  title                 String
  kind                  AiConversationKind @default(coach)
  scenario              String?
  speakingIsCompleted   Boolean     @default(false)
  speakingCompletedAt   DateTime?
  speakingFinalBand     String?
  speakingEstimatedBand String?
  speakingFluencyBand   String?
  speakingLexicalBand   String?
  speakingGrammarBand   String?
  speakingPronunciationBand String?
  speakingAssessmentSummary String?
  speakingStrengths     String[]    @default([])
  speakingImprovements  String[]    @default([])
  speakingLastAssessedAt DateTime?
  provider              AiProvider  @default(mock)
  modelName             String
  lastProviderResponseId String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages              AiMessage[]
  assessments           AiSpeakingAssessmentSnapshot[]

  @@index([tenantId])
  @@index([userId, updatedAt(sort: Desc)])
}

model AiMessage {
  id                String        @id @default(cuid())
  tenantId          String?
  conversationId    String
  role              AiMessageRole
  content           String
  provider          AiProvider?
  modelName         String?
  providerResponseId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  conversation      AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId, createdAt(sort: Asc)])
}

model AiSpeakingAssessmentSnapshot {
  id                      String         @id @default(cuid())
  tenantId                String?
  conversationId          String
  sequenceNumber          Int
  estimatedBand           String
  fluencyBand             String
  lexicalBand             String
  grammarBand             String
  pronunciationBand       String
  summary                 String
  strengths               String[]       @default([])
  improvements            String[]       @default([])
  provider                AiProvider
  modelName               String
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  conversation            AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([conversationId, createdAt(sort: Desc)])
  @@unique([conversationId, sequenceNumber])
}
