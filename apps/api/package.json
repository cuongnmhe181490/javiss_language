{
  "name": "@polyglot/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ai:eval": "tsc -p tsconfig.json && node dist/ai-eval.js",
    "test": "pnpm --filter @polyglot/contracts build && pnpm --filter @polyglot/authz build && pnpm --filter @polyglot/tenant-core build && vitest run src --pool=threads",
    "test:integration": "vitest run src/prisma-repositories.integration.spec.ts --pool=threads"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@polyglot/authz": "workspace:*",
    "@polyglot/contracts": "workspace:*",
    "@polyglot/tenant-core": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
