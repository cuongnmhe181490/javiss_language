# Public web origin used for canonical URLs and auth redirects.
APP_ORIGIN=http://localhost:3000

# Backend API URL consumed by the web app in local development.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# Local API port. Production should be behind TLS and a managed gateway.
API_PORT=4000
PORT=4000

# API security/config. dev-header is local scaffold only and is blocked in production.
NODE_ENV=development
AUTH_MODE=dev-header
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=debug
AUDIT_EXPORT_STEP_UP_TTL_SECONDS=600
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=100
RATE_LIMIT_MAX_REQUESTS=100
API_MAX_BODY_BYTES=1048576
API_VERSION=0.1.0

# Local Docker Compose defaults only. Replace in real environments.
DATABASE_URL=postgresql://polyglot:polyglot_local_password@localhost:5432/polyglot_dev?schema=public
TEST_DATABASE_URL=postgresql://polyglot:polyglot_local_password@localhost:5432/polyglot_test?schema=public
REDIS_URL=redis://localhost:6379
TEST_REDIS_URL=redis://localhost:6379

# Smoke script options.
API_SMOKE_BASE_URL=http://127.0.0.1:4000
API_SMOKE_EXPECT_PERSISTENCE=1
API_SMOKE_RATE_LIMIT=0

# OIDC scaffold. Required when AUTH_MODE=oidc.
OIDC_ISSUER_URL=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_TENANT_CLAIM=tenant_id
OIDC_ROLES_CLAIM=roles
OIDC_SUB_CLAIM=sub
OIDC_EMAIL_CLAIM=email
OIDC_JWKS_TIMEOUT_MS=2000

# OpenTelemetry local defaults.
OTEL_SERVICE_NAME=polyglot-api-local
OTEL_EXPORTER_OTLP_ENDPOINT=

# Never add real provider keys or secrets to this example file.
